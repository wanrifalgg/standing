    <script>
        let isEditMode = false;

        function toggleEditMode() {
            const btn = document.getElementById('btnEdit');
            isEditMode = !isEditMode;

            if (isEditMode) {
                btn.textContent = "Simpan Data";
                btn.classList.add('saving');
                enableEditing();
            } else {
                btn.textContent = "Edit Data";
                btn.classList.remove('saving');
                disableEditing();
            }
        }

        function enableEditing() {
            // Ubah text data-key menjadi Input Field
            const textElements = document.querySelectorAll('[data-key]');
            textElements.forEach(el => {
                const currentText = el.textContent.trim();
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'editable-input';
                input.value = currentText;
                input.setAttribute('data-old-el', el.tagName);
                input.setAttribute('data-key-bind', el.getAttribute('data-key'));
                
                // Salin kelas/gaya dasar agar tidak merusak layout secara ekstrem saat mengetik
                if(el.classList.contains('match-id')) input.style.width = "35px";
                
                el.replaceWith(input);
            });
        }

        function disableEditing() {
            const inputs = document.querySelectorAll('.editable-input');
            inputs.forEach(input => {
                const key = input.getAttribute('data-key-bind');
                const originalTag = input.getAttribute('data-old-el') || 'span';
                const newValue = input.value;

                const newEl = document.createElement(originalTag);
                newEl.setAttribute('data-key', key);
                newEl.textContent = newValue;

                // Kembalikan class esensial yang hilang akibat replace
                if(key.includes('-id')) {
                    newEl.className = 'match-id';
                    // Sesuaikan posisi nomor pertandingan sebelah kanan
                    if(["m76-id","m78-id","m79-id","m80-id","m86-id","m88-id","m85-id","m87-id","m91-id","m92-id","m95-id","m96-id","m99-id","m100-id","m102-id","m103-id","m104-id"].includes(key)){
                        newEl.style.left = "auto";
                        newEl.style.right = "-32px";
                        newEl.style.textAlign = "left";
                    }
                } else if(key.includes('-t1') || key.includes('-t2')) {
                    newEl.className = 'team-name';
                }

                input.replaceWith(newEl);
            });

            // Opsional: Anda dapat menambahkan logika penyimpanan ke localStorage di sini agar data tidak hilang saat di-refresh.
        }
    </script>
